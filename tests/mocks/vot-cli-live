#!/bin/bash
# ============================================================
# Deny-stub vot-cli-live — сетевой guard для тестов
#
# Настоящий vot-cli-live ходит в внешний сервис перевода. Однажды тест уже сделал
# это по-настоящему: у YTDLP_BIN был env-override «для тестов», а у VOT_BIN его не
# было, и check_translate_deps безусловно перезатирал переменную бинарём рядом со
# скриптом. Прогон молча ушёл в сеть на ~22 секунды.
#
# Заглушка стоит в tests/mocks (он идёт первым в PATH), поэтому любой резолв через
# PATH попадает сюда и ПАДАЕТ ГРОМКО вместо тихого сетевого вызова. Тест, которому
# перевод нужен по существу, обязан подставить свой мок явно через VOT_BIN — это
# осознанное действие, а не случайный дефолт.
#
# MOCK_VOT_ALLOW=1 снимает запрет (для самопроверки guard'а).
# ============================================================

echo "$@" >> "${MOCK_VOT_LOG:-/tmp/mock_vot_calls.txt}"

if [ "${MOCK_VOT_ALLOW:-0}" = "1" ]; then
    # Разрешённый режим: ведём себя как успешный перевод — создаём выходной файл.
    for a in "$@"; do
        case "$a" in --output=*) printf 'MOCK-VOT-AUDIO' > "${a#--output=}" ;; esac
    done
    exit 0
fi

echo "[СЕТЕВОЙ GUARD] Тест попытался запустить настоящий vot-cli-live: $*" >&2
echo "[СЕТЕВОЙ GUARD] Тесты не имеют права ходить в сеть. Подставьте мок через VOT_BIN." >&2
exit 97
