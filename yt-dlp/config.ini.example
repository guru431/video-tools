[proxy]
# Оставить пустым если прокси не нужен
# Формат: [scheme]://[user:pass@]host[:port]
# Пример: https://username:password@proxy.example.com:443
# Поддерживается подстановка из окружения: url = ${PROXY_URL}
# (несколько вхождений ок; не заданная переменная -> пустая строка + WARN)
url =

[cookies]
# Метод: none, file, browser
method = none
# Путь к файлу cookies (при method=file)
file = youtube_cookies.txt
# Браузер для извлечения cookies (при method=browser): chrome, firefox, edge
browser = chrome

[output]
# Базовая папка для загрузок
base_dir = _video_
# Шаблон имени файла для одиночных видео
template = %(uploader)s/%(upload_date)s - %(title).100U.%(ext)s
# Шаблон для плейлистов
playlist_template = %(uploader)s/%(playlist)s/%(playlist_index)03d - %(title).100U.%(ext)s

[download]
# Качество по умолчанию: 360, 480, 720, 1080, 1440, 2160, audio
# audio — скачать только аудиодорожку (формат задаётся ключом audio_format ниже).
default_quality = 720
# Пресет формата: auto, avc1_best, avc1_https, avc1_m3u8,
#   avc1_https_60fps, avc1_m3u8_60fps, avc1_https_60fps_hdr, old_combo
# auto: для YouTube = avc1_best, для VK/RuTube/прочих = простой best (один поток, быстро)
format_preset = auto
# Продолжать при ошибках в плейлисте
continue_on_error = true
# Пропускать уже скачанные видео (download archive)
use_archive = true
archive_file = download_archive.txt
# Формат аудио при выборе "только аудио": best (как отдаёт сервер), mp3, m4a, opus
audio_format = best
# SponsorBlock: off (выкл), mark (отметить главами), remove (вырезать сегменты)
sponsorblock = off

[subtitles]
# Язык субтитров
lang = ru
# Формат: vtt, srt
format = vtt
# Скачивать субтитры вместе с видео: off, sidecar (отдельный файл), embed (встроить в контейнер)
download_with_video = off

[batch]
# Период для batch-загрузки: now-1month, now-3months, now-6months, now-1year
date_range = now-6months
# Задержки между запросами (секунды) — защита от блокировки
sleep_requests = 1.8
sleep_interval = 8
max_sleep_interval = 22
sleep_subtitles = 4

[trim]
# Скачать фрагмент ролика. Формат: ЧЧ:ММ:СС, М:СС, или секунды.
# +/- перед значением — включено/выключено. Комбинации:
#   только start  = с TIME до конца ролика  (вырезать "хвост")
#   только end    = с начала до TIME        (вырезать "начало")
#   start + end   = фрагмент TIME1..TIME2   (вырезать "середину")
#   обе выкл      = весь ролик
start = -00:00:00
end   = -00:01:00
# Точная обрезка по границам (перекодирует только концы фрагмента, медленнее).
# Без этого yt-dlp режет по ближайшему ключевому кадру (быстро, но ±1-10 сек).
force_keyframes = false

[translation]
# Включить AI-перевод аудиодорожки: true/false
enabled = false
# Язык перевода: ru, en, kk
target_lang = ru
# Стиль голоса: live (живые голоса) / tts (синтез)
voice_style = live
# Режим: dual_track (2 дорожки) / replace (заменить оригинал) / mix (смешать)
mode = mix
# Громкость оригинала при mode=mix (0.0-2.0)
original_volume = 0.3
# Громкость перевода при mode=mix (0.0-2.0)
translation_volume = 1.0
# Язык оригинала (для метаданных дорожки)
original_lang = en
