#!/bin/sh
# pre-commit secret-guard for a PUBLIC repository.
# Blocks commits that add sensitive files, high-entropy key formats, or
# personal strings listed in an untracked .sanitize-patterns file.
#
# Activate once per clone:   git config core.hooksPath .githooks
# Bypass a confirmed false positive:   git commit --no-verify
set -eu

repo_root=$(git rev-parse --show-toplevel)
fail=0

# 1) Block sensitive filenames being newly added (allow *.example* templates)
added=$(git diff --cached --name-only --diff-filter=A || true)
if [ -n "$added" ]; then
  bad=$(printf '%s\n' "$added" \
    | grep -iE '(^|/)(\.env(\.[A-Za-z0-9]+)?$|.*\.pem$|.*\.key$|.*\.p12$|.*\.pfx$|id_rsa|id_ed25519|id_dsa|vault\.env|\.sanitize-patterns$)' \
    | grep -ivE '\.example(\.|$)' || true)
  if [ -n "$bad" ]; then
    echo "BLOCKED: refusing to commit sensitive file(s):"
    printf '  %s\n' $bad
    fail=1
  fi
fi

# Collect staged diff once (exclude the hook itself to avoid self-matching).
# ONLY ADDED lines: the scanner used to see the whole diff, so a remediation commit
# that DELETES a leaked token contained "-ghp_..." and got blocked — exactly when it
# must pass. That pushed people toward --no-verify, disabling every other check too.
# --unified=0 → no context lines; '^+' keeps additions, '^+++' drops the file header.
diff_content=$(
  { git diff --cached --unified=0 -- . ':(exclude).githooks/pre-commit' 2>/dev/null \
    || git diff --cached --unified=0 -- . ':(exclude).githooks/pre-commit'; } \
  | grep '^+' | grep -v '^+++' || true
)

# 2) High-confidence secret/token formats (generic, very low false-positive)
generic='-----BEGIN [A-Z ]*PRIVATE KEY-----|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|gho_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{10,}|sk-[A-Za-z0-9_-]{16,}|ccr-[A-Za-z0-9]{8,}|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]+|[0-9]{8,10}:[A-Za-z0-9_-]{35}|[A-Za-z][A-Za-z0-9+.-]*://[^/@:[:space:]]+:[^/@[:space:]]+@'
# Exempt the documented proxy template placeholders (user:pass@, username:password@)
hits=$(printf '%s\n' "$diff_content" | grep -nE -e "$generic" | grep -vE '(^|[^A-Za-z0-9])(username:password|user:pass)@' || true)
if [ -n "$hits" ]; then
  echo "BLOCKED: possible secret/token format in staged changes:"
  printf '%s\n' "$hits" | sed 's/^/  /'
  fail=1
fi

# 3) Personal denylist — concrete values from untracked .sanitize-patterns
sp="$repo_root/.sanitize-patterns"
if [ -f "$sp" ]; then
  pat=$(mktemp 2>/dev/null || echo "$repo_root/.sanitize-patterns.tmp")
  # Отбрасываем пустые строки И комментарии (#) — формат из .sanitize-patterns.example.
  grep -vE '^[[:space:]]*($|#)' "$sp" > "$pat" 2>/dev/null || true
  if [ -s "$pat" ]; then
    # grep -F (fixed-strings): литералы denylist'а не трактуются как regex —
    # иначе метасимвол в значении (или битый ERE) ронял grep -> rc!=0 -> `|| true`
    # глушил -> denylist молча отключался. -i НЕЛЬЗЯ: на GNU grep 3.0 (Git for
    # Windows) комбинация -iF падает с SIGABRT (rc=134), и тот же `|| true` снова
    # глушил бы провал. Регистронезависимость — приведением обеих сторон к нижнему
    # регистру (tr) + grep -nFf без -i.
    patlc=$(mktemp 2>/dev/null || echo "$repo_root/.sanitize-patterns.lc")
    tr 'A-Z' 'a-z' < "$pat" > "$patlc" 2>/dev/null || true
    hits=$(printf '%s\n' "$diff_content" | tr 'A-Z' 'a-z' | grep -nFf "$patlc" || true)
    rm -f "$patlc"
    if [ -n "$hits" ]; then
      echo "BLOCKED: personal data (matched .sanitize-patterns) in staged changes:"
      printf '%s\n' "$hits" | sed 's/^/  /'
      fail=1
    fi
  fi
  rm -f "$pat"
fi

# 4) Binary blobs (tracked EXE etc.): text diff (blocks 2-3) can't see inside them.
#    Extract printable strings from the STAGED blob and re-run the secret-format +
#    personal-denylist checks. Best-effort: unreadable blobs are skipped, not blocked.
bins=$(git diff --cached --numstat --diff-filter=AM | awk -F'\t' '$1=="-" && $2=="-" { print $3 }')
if [ -n "$bins" ]; then
  bin_report=$(mktemp 2>/dev/null || echo "$repo_root/.pc_binscan.tmp")
  printf '%s\n' "$bins" | while IFS= read -r bf; do
    [ -n "$bf" ] || continue
    strs=$(git show ":$bf" 2>/dev/null | grep -aoE '[[:print:]]{6,}' || true)
    [ -n "$strs" ] || continue
    gh=$(printf '%s\n' "$strs" | grep -nE -e "$generic" | grep -vE '(^|[^A-Za-z0-9])(username:password|user:pass)@' || true)
    if [ -n "$gh" ]; then
      { echo "  [$bf] secret/token format:"; printf '%s\n' "$gh" | head -5 | sed 's/^/    /'; } >> "$bin_report"
    fi
    if [ -f "$sp" ]; then
      dl=$(grep -vE '^[[:space:]]*($|#)' "$sp" 2>/dev/null || true)
      if [ -n "$dl" ]; then
        dlf=$(mktemp 2>/dev/null || echo "$repo_root/.pc_dl.tmp")
        printf '%s\n' "$dl" | tr 'A-Z' 'a-z' > "$dlf"
        ph=$(printf '%s\n' "$strs" | tr 'A-Z' 'a-z' | grep -nFf "$dlf" || true)
        rm -f "$dlf"
        if [ -n "$ph" ]; then
          { echo "  [$bf] personal denylist match:"; printf '%s\n' "$ph" | head -5 | sed 's/^/    /'; } >> "$bin_report"
        fi
      fi
    fi
  done
  if [ -s "$bin_report" ]; then
    echo "BLOCKED: sensitive strings inside staged binary artifact(s):"
    cat "$bin_report"
    fail=1
  fi
  rm -f "$bin_report"
fi

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "Commit aborted — this is a PUBLIC repository."
  echo "Fix the lines above, or for a confirmed false positive: git commit --no-verify"
  exit 1
fi
exit 0
