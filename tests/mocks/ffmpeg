#!/bin/bash
# ============================================================
# Mock ffmpeg — перехватывает аргументы, имитирует работу
#
# Переменные окружения для управления поведением:
#   MOCK_FFMPEG_ENCODERS=nvenc  — вернуть "nvenc" при -encoders
#   MOCK_FFMPEG_ENCODERS=qsv   — вернуть "qsv" при -encoders
#   MOCK_FFMPEG_ENCODERS=       — пустой список (по умолчанию)
#   MOCK_FFMPEG_FAIL=1         — вернуть exit code 1
#   MOCK_FFMPEG_LOG=           — путь к файлу лога (по умолчанию /tmp/mock_ffmpeg_calls.txt)
#   MOCK_FFMPEG_SILENCE="10:12 25:27" — при -af silencedetect эмитить пары
#                                       silence_start/silence_end (секунды)
# ============================================================

LOG_FILE="${MOCK_FFMPEG_LOG:-/tmp/mock_ffmpeg_calls.txt}"
ENCODERS="${MOCK_FFMPEG_ENCODERS:-}"
FAIL="${MOCK_FFMPEG_FAIL:-0}"
BITRATE="${MOCK_FFMPEG_BITRATE:-2000}"
# Битрейт видеопотока отдельно от контейнерного: они РАЗНЫЕ (контейнер = видео +
# аудио + overhead). MOCK_FFMPEG_VIDEO_BITRATE="" убирает `kb/s` из строки Video —
# так ведут себя MKV/WebM, не сообщающие per-stream битрейт.
VIDEO_BITRATE="${MOCK_FFMPEG_VIDEO_BITRATE-1808}"
DURATION="${MOCK_FFMPEG_DURATION:-00:01:00.00}"
AUDIO_CODEC="${MOCK_FFMPEG_AUDIO_CODEC:-aac}"

# Записать полный вызов в лог
echo "$@" >> "$LOG_FILE"

# Если -encoders — вернуть список кодеков
if [[ "$*" == *"-encoders"* ]]; then
    echo "Encoders:"
    echo " V..... libx264"
    echo " V..... libx265"
    echo " V..... libsvtav1"
    if [ -n "$ENCODERS" ]; then
        echo " V..... ${ENCODERS}_example"
    fi
    exit 0
fi

# Если -version — вернуть версию
if [[ "$*" == *"-version"* ]]; then
    echo "ffmpeg version 6.0 (mock)"
    exit 0
fi

# При наличии -i — всегда выводить медиа-информацию в stderr
# (как реальный ffmpeg при любом вызове с -i)
if [[ "$*" == *" -i "* ]] || [[ "$*" == "-i "* ]]; then
    if [ -n "$VIDEO_BITRATE" ]; then
        VSTREAM="    Stream #0:0(und): Video: h264 (High), yuv420p, 1920x1080, ${VIDEO_BITRATE} kb/s, 30 fps, 30 tbr, 15360 tbn"
    else
        VSTREAM="    Stream #0:0(und): Video: h264 (High), yuv420p, 1920x1080, 30 fps, 30 tbr, 15360 tbn"
    fi
    cat << MEDIAEOF >&2
ffmpeg version 6.0 (mock)
Input #0, mov,mp4,m4a,3gp,3g2,mj2, from 'input.mp4':
  Metadata:
    encoder         : Lavf58.76.100
  Duration: ${DURATION}, start: 0.000000, bitrate: ${BITRATE} kb/s
${VSTREAM}
    Stream #0:1(und): Audio: ${AUDIO_CODEC}, 48000 Hz, stereo, fltp, 192 kb/s
MEDIAEOF
fi

# Имитация silencedetect: синтетические silence_start/silence_end в stderr
# (реальный ffmpeg пишет их туда; script.sh делает 2>&1 | grep silence_).
if [[ "$*" == *"silencedetect"* ]] && [ -n "${MOCK_FFMPEG_SILENCE:-}" ]; then
    for _pair in $MOCK_FFMPEG_SILENCE; do
        _s="${_pair%%:*}"; _e="${_pair##*:}"
        echo "[silencedetect @ 0x0] silence_start: ${_s}" >&2
        echo "[silencedetect @ 0x0] silence_end: ${_e} | silence_duration: 2" >&2
    done
fi

# Имитация прогресса для -progress
PROGRESS_FILE=""
PREV_ARG=""
for arg in "$@"; do
    if [ "$PREV_ARG" = "-progress" ]; then
        PROGRESS_FILE="$arg"
        break
    fi
    PREV_ARG="$arg"
done

if [ -n "$PROGRESS_FILE" ] && [ "$PROGRESS_FILE" != "pipe:1" ]; then
    {
        echo "frame=25"
        echo "fps=25.0"
        echo "stream_0_0_q=28.0"
        echo "bitrate=500.0kbits/s"
        echo "total_size=62500"
        echo "out_time_us=1000000"
        echo "out_time=00:00:01.000000"
        echo "dup_frames=0"
        echo "drop_frames=0"
        echo "speed=1.0x"
        echo "progress=end"
    } > "$PROGRESS_FILE"
fi

# Создать выходной файл (если указан -i и выходной аргумент).
# Последний non-flag аргумент = выходной файл, КРОМЕ:
#   - значений опций после -f (null/lavfi/...) и -v (verbose/error/...);
#     иначе E3-валидация `-f null -` в script.sh создаёт файл `null` в cwd.
#   - special outputs: `-` (stdout), `pipe:N`.
LAST_ARG=""
PREV=""
SKIP_OPTS=("-f" "-v" "-loglevel" "-c" "-c:v" "-c:a" "-c:s" "-b:v" "-b:a" "-ac" "-ar"
           "-r" "-t" "-ss" "-to" "-threads" "-preset" "-tune" "-rc" "-cq" "-crf"
           "-global_quality" "-vf" "-af" "-filter_complex" "-map" "-progress"
           "-hwaccel" "-hwaccel_output_format" "-i" "-metadata" "-metadata:s:s:0"
           "-disposition:a:0" "-strict" "-pix_fmt" "-s")
is_opt_value=0
for arg in "$@"; do
    if [ "$is_opt_value" = "1" ]; then
        is_opt_value=0
        PREV="$arg"
        continue
    fi
    for o in "${SKIP_OPTS[@]}"; do
        if [ "$arg" = "$o" ]; then is_opt_value=1; break; fi
    done
    if [ "$is_opt_value" = "0" ] && [[ "$arg" != -* ]]; then
        LAST_ARG="$arg"
    fi
    PREV="$arg"
done
if [ -n "$LAST_ARG" ] \
   && [[ "$LAST_ARG" != *"pipe:"* ]] \
   && [ "$LAST_ARG" != "-" ] \
   && [ "$LAST_ARG" != "null" ]; then
    touch "$LAST_ARG" 2>/dev/null || true
fi

[ "$FAIL" = "1" ] && exit 1
exit 0
